---
---
<section class="py-24 bg-white border-y border-slate-50">
  <div class="container mx-auto px-6">
    <div class="flex flex-col md:flex-row items-center gap-16 md:gap-24">
      <!-- Image -->
      <div class="w-full md:w-1/2 max-w-lg">
        <div class="relative group">
          <div class="absolute -inset-4 border-2 border-slate-100 rounded-sm -z-10 transition-all group-hover:inset-0 group-hover:border-slate-900"></div>
          <img 
            src="/assets/founder.png" 
            alt="Dr. Cristina Codina" 
            class="w-full rounded-sm grayscale shadow-2xl filter contrast-125"
          />
        </div>
      </div>

      <!-- Text -->
      <div class="w-full md:w-1/2">
        <span class="text-[10px] font-bold uppercase tracking-[0.2em] text-blue-600">The Founder</span>
        <h2 class="text-3xl md:text-5xl font-bold text-slate-900 mt-4 mb-8 tracking-tight leading-tight">
          Bridging Technical Logic with Editorial Precision.
        </h2>
        <p class="text-slate-600 leading-relaxed mb-8">
          Dr. Cristina Codina is an award-winning scholar recognized for her transformative work in bilingual acceleration. At Cris Academy, she applies cognitive load theory and engineering logic to high-stakes communication, turning linguistic barriers into strategic professional assets.
        </p>
        
        <div class="grid grid-cols-2 gap-8 border-t border-slate-100 pt-8">
          <div>
            <div class="text-2xl font-bold text-slate-900 tracking-tight">15+</div>
            <p class="text-[10px] font-bold uppercase tracking-widest text-slate-400 mt-1">Years of Research</p>
          </div>
          <div>
            <div class="text-2xl font-bold text-slate-900 tracking-tight text-balance">TABE</div>
            <p class="text-[10px] font-bold uppercase tracking-widest text-slate-400 mt-1">Higher Ed Honoree</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
