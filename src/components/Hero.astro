---
---
<section class="relative pt-16 pb-24 md:pt-24 md:pb-32 overflow-hidden">
  <div class="container mx-auto px-6">
    <div class="flex flex-col lg:flex-row items-center gap-16">
      
      <!-- Content -->
      <div class="flex-1 max-w-2xl">
        <div class="inline-flex items-center space-x-2 px-3 py-1 rounded-full bg-slate-50 border border-slate-100 mb-8">
          <span class="relative flex h-2 w-2">
            <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-blue-400 opacity-75"></span>
            <span class="relative inline-flex rounded-full h-2 w-2 bg-blue-500"></span>
          </span>
          <span class="text-[10px] font-bold uppercase tracking-widest text-slate-500">Autumn 2026 Enrollment Open</span>
        </div>

        <h1 class="text-4xl md:text-6xl font-bold text-slate-900 leading-[1.1] mb-6 tracking-tight">
          The Science of <span class="block">High-Stakes</span> Communication for Engineers.
        </h1>
        
        <p class="text-lg text-slate-600 mb-10 leading-relaxed max-w-xl">
          Master the editorial precision of technical storytelling with <strong>Dr. Cristina Codina</strong>, Higher Ed Honoree and expert in bilingual acceleration for Senior Software Engineers aiming for FAANG roles.
        </p>

        <div class="flex flex-col sm:flex-row gap-4 mb-12">
          <a href="#enroll" class="bg-slate-900 text-white px-8 py-4 rounded-sm text-sm font-bold hover:bg-slate-800 transition-all shadow-xl shadow-slate-200">
            Apply for the Cohort
          </a>
          <a href="#curriculum" class="bg-slate-50 text-slate-600 px-8 py-4 rounded-sm text-sm font-bold hover:bg-slate-100 transition-all">
            View Curriculum
          </a>
        </div>

        <div class="flex items-center gap-8 border-t border-slate-100 pt-8">
          <span class="text-[10px] font-bold uppercase tracking-widest text-slate-400">Alumni at:</span>
          <div class="flex gap-6 opacity-40 grayscale">
             <!-- Placeholder logos/text -->
             <span class="font-bold text-xs">GOOGLE</span>
             <span class="font-bold text-xs">META</span>
             <span class="font-bold text-xs">AMAZON</span>
             <span class="font-bold text-xs">NETFLIX</span>
          </div>
        </div>
      </div>

      <!-- Hero Visual -->
      <div class="flex-1 relative w-full lg:max-w-xl">
        <div class="relative aspect-[4/5] rounded-sm overflow-hidden shadow-2xl border border-slate-100 bg-slate-50">
          <img 
            src="/assets/hero.png" 
            alt="Elite Academic Environment" 
            class="w-full h-full object-cover"
          />
          <div class="absolute bottom-6 left-6 right-6">
            <div class="bg-white p-6 rounded-sm shadow-2xl border border-slate-50 max-w-[240px]">
                <div class="text-3xl font-bold text-slate-900">94%</div>
                <p class="text-[10px] font-bold uppercase tracking-wider text-slate-500 mt-1 leading-tight">
                    Placement rate at Tier-1 tech firms within 6 months.
                </p>
            </div>
          </div>
        </div>
        <!-- Decorative element -->
        <div class="absolute -top-12 -right-12 w-64 h-64 bg-slate-50 rounded-full -z-10 blur-3xl opacity-50"></div>
      </div>

    </div>
  </div>
</section>
