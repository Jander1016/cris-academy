<section class="py-24 bg-white">
  <div class="container mx-auto px-6 text-center">
    <div class="max-w-4xl mx-auto">
      <div class="w-12 h-1 bg-slate-200 mx-auto mb-16"></div>
      <blockquote class="text-2xl md:text-4xl font-medium text-slate-900 leading-tight italic tracking-tight">
        "English isn't just a language for the senior engineer—it's the most powerful tool in your tech stack. It's the difference between executing a ticket and leading a department."
      </blockquote>
      
      <div class="mt-12 flex items-center justify-center gap-4">
        <div class="w-10 h-10 rounded-full bg-slate-100 overflow-hidden grayscale border border-slate-100">
            <img src="/assets/founder.png" alt="Founder Icon" class="w-full h-full object-cover">
        </div>
        <div class="text-left">
          <p class="text-xs font-bold text-slate-900 uppercase tracking-widest leading-none">Cris Academic Director</p>
          <p class="text-[10px] text-slate-500 font-bold uppercase tracking-widest mt-1">Ex-Google Senior Lead</p>
        </div>
      </div>
    </div>
  </div>
</section>
